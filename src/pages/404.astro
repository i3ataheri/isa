---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="صفحه پیدا نشد">
  <main style="display:flex;align-items:center;justify-content:center;min-height:100vh;text-align:center;padding:2rem">
    <div>
      <h1 style="font-size:4rem;margin-bottom:0.5rem;color:var(--color-accent)">۴۰۴</h1>
      <p style="font-size:1.1rem;margin-bottom:1.5rem;color:var(--color-text-muted)">صفحه‌ای که دنبالش بودی پیدا نشد!</p>
      <a href="/" style="display:inline-block;background:var(--color-accent);color:var(--color-text-inverse);padding:0.6rem 1.5rem;border-radius:8px;text-decoration:none">برو به خانه</a>
    </div>
  </main>
</BaseLayout>
