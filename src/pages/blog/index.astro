---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Search from "../../icons/Search.astro";
import Home from "../../icons/Home.astro";
import About from "../../icons/About.astro";
import Moon from "../../icons/Moon.astro";
import Sun from "../../icons/Sun.astro";
import Logo from "../../icons/Logo.astro";
import { menu } from "../../data/menu";
import { links } from "../../data/links";
import { getCollection } from "astro:content";
import fs from "fs";

function mtime(p: { id: string }) {
  try { return fs.statSync("src/content/blog/" + p.id).mtimeMs; } catch { return 0; }
}

const allPosts = await getCollection("blog");
function getCats(p: { data: { category?: string | string[] } }): string[] {
  if (!p.data.category) return [];
  return Array.isArray(p.data.category) ? p.data.category : [p.data.category];
}
const published = allPosts.filter((p) => !p.data.draft).sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0) || mtime(b) - mtime(a));
const recent = published.slice(0, 5);
const random = published.toSorted(() => Math.random() - 0.5).slice(0, 3);
const seriesPosts = published.filter((p) => p.data.series);
const seriesGroups = [...new Set(seriesPosts.map((p) => p.data.series).filter(Boolean))].map((s) => ({
  name: s as string,
  posts: seriesPosts.filter((p) => p.data.series === s).sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0)),
}));

const catColors = ["#9f1239", "#dc2626", "#2563eb", "#d97706", "#7c3aed", "#0891b2", "#65a30d", "#be123c", "#9333ea", "#0d9488"];
const sections = menu.map((m) => m.s).filter(Boolean);
const cats = [
  { name: "همه", color: catColors[0], count: allPosts.length },
  ...sections.map((s, i) => ({
    name: s,
    color: catColors[(i + 1) % catColors.length],
    count: allPosts.filter((p) => getCats(p).includes(s)).length,
  })),
];

function monthName(d: Date) {
  return d.toLocaleDateString("fa-IR", { year: "numeric", month: "long" });
}

const months = new Map<string, number>();
for (const p of published) {
  if (p.data.date) {
    const k = monthName(p.data.date);
    months.set(k, (months.get(k) || 0) + 1);
  }
}
const archive = [...months.entries()].slice(0, 6);

const grouped = sections.map((s) => ({
  name: s,
  posts: published.filter((p) => getCats(p).includes(s)),
})).filter((g) => g.posts.length > 0);

const uncategorized = published.filter((p) => !p.data.category);
if (uncategorized.length > 0) grouped.push({ name: "متفرقه", posts: uncategorized });
---

<BaseLayout title="همه مطالب — عیسی طاهری" description="تمام نوشته‌های عیسی طاهری">
  <div class="dashboard">
    <!-- menu -->
    <aside class="col-menu">
      <div class="menu-logo"><a href="/"><Logo /><span class="wi-tip">عیسی طاهری</span></a></div>
      <div class="w-icons" style="margin-bottom:1rem">
        <a href="/" class="wi-btn"><Home /><span class="wi-tip">خانه</span></a>
        <button class="wi-btn" id="about-btn"><About /><span class="wi-tip">درباره من</span></button>
        <button class="wi-btn" id="search-btn"><Search /><span class="wi-tip">جستجو</span></button>
        <button class="wi-btn" id="th-one"><span id="th-moon"><Moon /></span><span id="th-sun" style="display:none"><Sun /></span><span class="wi-tip">تم</span></button>
      </div>
      <div class="menu-list">
        {menu.map((item) => (
          <>
            <div class="menu-sec">{item.s}</div>
            {item.i.map((sub) => <a href={sub.h} class="menu-sub">{sub.l}</a>)}
          </>
        ))}
      </div>
    </aside>

    <!-- widget col 1 -->
    <div class="col-w1">
      <div class="w-mini">
        <div class="w-mini-title">مجموعه مقالات</div>
        {seriesGroups.length > 0 ? seriesGroups.map((sg) => (<><div class="series-group-name">{sg.name}</div><ul class="item-list">{sg.posts.map((p) => (<li><a href={`/blog/${p.slug}`}>{p.data.title}</a></li>))}</ul></>)) : <ul class="item-list"><li style="font-size:0.65rem;color:var(--color-text-muted)">مجموعه‌ای وجود ندارد</li></ul>}
      </div>
      <div class="w-mini">
        <div class="w-mini-title">تصادفی</div>
        <ul class="item-list">
          {random.map((r) => (<li><a href={`/blog/${r.slug}`}>{r.data.title}<span class="item-meta">({r.data.category})</span></a></li>))}
        </ul>
      </div>
      <div class="w-mini w-mini-sm">
        <div class="w-mini-title">دسته‌بندی</div>
        <ul class="cat-list">
          {cats.map((c) => (
            <li><a href="javascript:void(0)"><span class="cat-dot" style={`background:${c.color}`}></span>{c.name}<span class="cat-num">{c.count}</span></a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- widget col 2 -->
    <div class="col-w2">
      <div class="w-mini">
        <div class="w-mini-title">جدیدترین</div>
        <ul class="item-list">
          {recent.map((r) => (<li><a href={`/blog/${r.slug}`}>{r.data.title}</a></li>))}
        </ul>
      </div>
      <div class="w-mini">
        <div class="w-mini-title">آرشیو</div>
        <ul class="arch-list">
          {archive.map(([l, n]) => (<li><a href="javascript:void(0)">{l}<span class="arch-num">{n}</span></a></li>))}
        </ul>
      </div>
      <div class="w-mini">
        <div class="w-mini-title">لینک‌های مفید</div>
        <ul class="link-list">
          {links.map((ln) => (<li class="link-li"><a href={ln.h} target="_blank" rel="noopener">{ln.l}<span class="link-tip">{ln.t}</span></a></li>))}
        </ul>
      </div>
    </div>

    <!-- content -->
    <main class="col-content">
      <div class="blog-listing-sections">
        <h1 class="blog-listing-title">همه مطالب</h1>
        {grouped.map((g) => (
          <section class="blog-section">
            <h2 class="blog-section-title">{g.name}</h2>
            <ul class="blog-section-list">
              {g.posts.map((p) => (
                <li><a href={`/blog/${p.slug}`}>{p.data.title}</a></li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </main>
  </div>

  <script>
    const btn = document.getElementById("th-one");
    const moon = document.getElementById("th-moon");
    const sun = document.getElementById("th-sun");
    const h = document.documentElement;
    function sync() {
      const d = h.getAttribute("data-theme") === "dark";
      moon.style.display = d ? "none" : "";
      sun.style.display = d ? "" : "none";
    }
    sync();
    btn.addEventListener("click", () => {
      const d = h.getAttribute("data-theme") === "dark";
      if (d) { h.removeAttribute("data-theme"); localStorage.setItem("theme", "light"); }
      else { h.setAttribute("data-theme", "dark"); localStorage.setItem("theme", "dark"); }
      sync();
    });
    document.getElementById("search-btn")?.addEventListener("click", () => {
      const m = document.querySelector("pagefind-modal");
      if (m && typeof m.open === "function") { m.open(); return; }
      const im = window.PagefindComponents?.getInstanceManager?.();
      const inst = im?.getInstance?.("default");
      const modal = inst?.getUtilities?.("modal")?.[0];
      if (modal && typeof modal.open === "function") modal.open();
    });
    const ab = document.getElementById("about-btn");
    const am = document.getElementById("about-modal");
    ab?.addEventListener("click", () => am?.showModal());
    document.getElementById("about-close")?.addEventListener("click", () => am?.close());
    am?.addEventListener("click", (e) => { if (e.target === am) am.close(); });
    const params = new URLSearchParams(location.search);
    const cat = params.get("cat");
    if (cat) {
      document.querySelectorAll(".blog-section").forEach((s) => {
        const title = s.querySelector(".blog-section-title")?.textContent;
        if (title !== cat) s.style.display = "none";
      });
      const h1 = document.querySelector(".blog-listing-title");
      if (h1) h1.textContent = cat;
    }
  </script>

  <dialog id="about-modal" class="about-dialog">
    <button class="about-close" id="about-close" aria-label="بستن">&times;</button>
    <h2 class="about-title">درباره من</h2>
    <p class="about-desc">نویسنده و فعال دینی اهل سنت از خراسان زمین ساکن در دیار وحی</p>
    <p class="about-body">می‌نویسم از دین، باورهای فراموش‌شده و نگاه نقادانه به سنت و مدرنیته. اینجا جایی است برای مرور آنچه نادیده گرفته شده، بازخوانی باورهای کهن از منظری تازه، و گفت‌وگو دربارهٔ مسائل اعتقادی و اجتماعیِ جهان اسلام.</p>
  </dialog>
</BaseLayout>
